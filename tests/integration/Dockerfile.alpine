FROM alpine:3.20

RUN apk add --no-cache \
    python3 \
    py3-pip \
    git \
    age \
    curl \
    bash \
    && python3 -m venv /opt/venv

# Ensure git is usable in tests
RUN git config --global user.email "ci@rv-test.local" && \
    git config --global user.name "Revive CI"

WORKDIR /app
COPY . /app

RUN /opt/venv/bin/pip install --quiet --upgrade pip && \
    /opt/venv/bin/pip install --quiet -e ".[dev]"

ENV PATH="/opt/venv/bin:$PATH"

CMD ["python", "-m", "pytest", "tests/integration/test_full_lifecycle.py", "-v", "--tb=short"]
